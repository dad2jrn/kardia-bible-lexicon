# ── Node / npm ──────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json        # committed at workspace root only; sub-package locks ignored
!tools/kardia-generator-app/package-lock.json

# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/
out/
.vite/

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Vite / bundler cache ─────────────────────────────────────────────────────
.vite-cache/

# ── SQLite (local data only) ─────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor & OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ── Python (kept — repo may still contain Python tooling) ────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
